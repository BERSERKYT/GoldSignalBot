# GoldSignalBot V1 – API Keys Template
# Copy this file to .env and fill in your real API keys.
# Command: cp .env.example .env

# ─── Data Sources ─────────────────────────────────────────────────────────────
# Priority 1: GoldAPI.io (free realtime + historical XAU/USD)
# Sign up at: https://www.goldapi.io/dashboard
GOLDAPI_KEY=your_goldapi_key_here

# Priority 2: MetalpriceAPI (free tier, 100 req/month)
# Sign up at: https://metalpriceapi.com/
METALPRICE_KEY=your_metalprice_key_here

# ─── News / Economic Calendar ──────────────────────────────────────────────────
# Finnhub (free tier – no auth needed for basic calendar, but key gives higher limits)
# Sign up at: https://finnhub.io/dashboard
FINNHUB_KEY=your_finnhub_key_here

# ─── Notes ────────────────────────────────────────────────────────────────────
# yfinance (GC=F) is used as the final data fallback and for backtesting.
# It requires NO API key – data is pulled directly from Yahoo Finance.
